{
    "name": "doc-pipeline-sandbox",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "concurrently -k -n server,web -c blue,magenta \"npm run server\" \"npm run web\"",
        "server": "tsx watch src/server.ts",
        "web": "vite",
        "build": "vite build",
        "typecheck": "tsc --noEmit",
        "test": "echo 'no tests'"
    },
    "dependencies": {
        "@hono/node-server": "^1.13.0",
        "effect": "^3.18.0",
        "livetrace": "^0.1.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0"
    },
    "devDependencies": {
        "@types/node": "^22.10.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@vitejs/plugin-react": "^5.0.0",
        "concurrently": "^9.0.0",
        "tsx": "^4.19.0",
        "typescript": "^5.7.0",
        "vite": "^7.0.0"
    }
}
